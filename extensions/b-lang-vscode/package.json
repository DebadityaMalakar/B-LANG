{
  "name": "b-lang",
  "displayName": "B Language Support",
  "description": "Syntax highlighting and LSP for the B language (MVP).",
  "version": "0.0.1",
  "publisher": "debaditya",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:b"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "b",
        "aliases": [
          "B",
          "b"
        ],
        "extensions": [
          ".b"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "b",
        "scopeName": "source.b",
        "path": "./syntaxes/b.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ -w",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}
